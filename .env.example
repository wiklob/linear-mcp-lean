# Inbound auth: the bearer token MCP clients must present on every request.
# Generate one: openssl rand -hex 32
MCP_BEARER_TOKEN=

# Outbound auth: a Linear Personal API Key.
# Linear → Settings → Security & access → Personal API keys.
LINEAR_API_KEY=

# Optional: HTTP port (default 8080).
# PORT=8080

# Optional: where the per-call byte log (JSONL) is appended (default ./byte-log.jsonl).
# Under systemd, point this at the StateDirectory (see deploy/linear-mcp.service).
# BYTE_LOG_PATH=./byte-log.jsonl
