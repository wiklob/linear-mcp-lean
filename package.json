{
  "name": "linear-mcp-lean",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted MCP server wrapping Linear's GraphQL API with response-shape control — lean reads, minimal write acks, drop-in tool names.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "probe:auth": "bash ./probe-auth.sh",
    "probe:tools": "bash ./probe-tools.sh",
    "probe:bytelog": "bash ./probe-bytelog-health.sh",
    "probe:status": "bash ./probe-project-status.sh",
    "probe:proxy": "bash ./probe-proxy.sh",
    "probe:secrets": "bash ./deploy/probe-secrets.sh",
    "probe:vs-hosted": "node ./probe-vs-hosted.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "graphql": "^16.9.0",
    "graphql-request": "^7.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
